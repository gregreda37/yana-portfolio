rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Username → UID lookup ───────────────────────────────────────────────
    match /usernames/{username} {
      // Anyone can read (needed for public portfolio lookup + availability check)
      allow read: if true;

      // Only allow a user to claim a username that maps to their own UID
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      // Only the uid owner can rename or delete their username entry
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.uid;
    }

    // ── Per-user documents ──────────────────────────────────────────────────
    match /users/{uid} {
      // Public read — portfolio pages are open to everyone
      allow read: if true;

      // Only the authenticated owner can write their own user doc
      allow write: if request.auth != null && request.auth.uid == uid;

      // ── Portfolio sections (profile, metrics, experience, …) ──────────────
      match /portfolio/{section} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // ── Resume requests from portfolio visitors ────────────────────────────
      match /resumeRequests/{requestId} {
        // Anyone can submit a request (public portfolio visitors, no auth required)
        allow create: if request.resource.data.status == 'pending';

        // Only the portfolio owner can read, update, or delete requests
        allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
