{
  "hosting": {
    "site": "yana-f9a11",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/admin",    "destination": "/index.html" },
      { "source": "/admin/**", "destination": "/index.html" },
      { "source": "**",        "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
